{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flowschool-static",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),path=require('path');h.createServer((req,res)=>{const f=path.join('public',req.url==='/'?'/index.html':req.url);try{const d=fs.readFileSync(f);res.writeHead(200,{'Content-Type':f.endsWith('.html')?'text/html':f.endsWith('.css')?'text/css':'application/javascript'});res.end(d);}catch{res.writeHead(404);res.end();}}).listen(4321);"],
      "port": 4321
    }
  ]
}
